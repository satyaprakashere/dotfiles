{
  "workbench.colorTheme": "GitHub Dark",
  "files.autoSave": "onFocusChange",
  "editor.fontSize": 18,
  "editor.minimap.autohide": "mouseover",
  "terminal.integrated.fontSize": 16,
  "haskell.manageHLS": "GHCup",
  "telemetry.editStats.enabled": false,
  "calva.telemetryEnabled": false,
  "git.openRepositoryInParentFolders": "always",
  "go.toolsManagement.autoUpdate": true,
  "markdown-preview-enhanced.enablePreviewZenMode": true,
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "markdown-preview-enhanced.codeBlockTheme": "atom-material.css",
  "kotlin.languageServer.enabled": false,
  "kotlin.debugAdapter.enabled": false,
  "zig.zls.enabled": "on",
  "explorer.confirmDelete": false,
  "telemetry.telemetryLevel": "off",
  "code-runner.enableAppInsights": false,
  "makefile.configureOnOpen": true,
  "explorer.confirmDragAndDrop": false,
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "window.customTitleBarVisibility": "windowed"
}