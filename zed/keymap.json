// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "j k": ["workspace::SendKeystrokes", "escape"]
    }
  },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "alt-r": "task::Rerun"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-cmd-r": "workspace::ToggleRightDock"
    }
  },
  {
    "bindings": {
      "alt-shift-h": "zed::Hide"
    }
  },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "cmd-h": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "cmd-b": ["task::Spawn", { "task_name": "Code Builder" }]
    }
  },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "cmd-r": [
        "task::Spawn",
        {
          "task_name": "Code Runner"
        }
      ]
    }
  },
  // {
  //   "context": "((Workspace || Editor) || Terminal)",
  //   "bindings": {
  //     "cmd-.": ["task::Terminate", { "task_name": "Code Runner" }]
  //   }
  // },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "cmd-shift-b": "task::Spawn"
    }
  },
  {
    "context": "((Workspace || Editor) || Terminal)",
    "bindings": {
      "cmd-l": "workspace::ToggleRightDock"
    }
  }
]
