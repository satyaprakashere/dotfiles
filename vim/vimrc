set nocompatible
let plug_plugin = expand('~/.config/vim/autoload/plug.vim')

if !filereadable(plug_plugin)
    echo "Installing plug..."
    echo ""
    silent !curl -fLo ~/.config/vim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim

    echo "Installing plugins..."
    echo ""
    :PlugInstall
endif

call plug#begin('~/.vim/plugged')

" Appearance
Plug 'catppuccin/vim', { 'as': 'catppuccin' }
Plug 'mhartington/oceanic-next'
Plug 'itchyny/lightline.vim'
Plug 'wojciechkepka/vim-github-dark'

" LSP and Completion
Plug 'neoclide/coc.nvim', {'branch': 'release'}
Plug 'honza/vim-snippets'
Plug 'jiangmiao/auto-pairs'
Plug 'tpope/vim-repeat'

" Search and Navigation
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'
Plug 'easymotion/vim-easymotion'
Plug 'christoomey/vim-sort-motion'
Plug 'gcmt/wildfire.vim'
Plug 'tpope/vim-fireplace'
Plug 'mg979/vim-visual-multi'

Plug 'guns/vim-sexp',    {'for': 'clojure'}
Plug 'liquidz/vim-iced', {'for': 'clojure'}

" Git Integration
Plug 'tpope/vim-fugitive'
Plug 'airblade/vim-gitgutter'
Plug 'jreybert/vimagit'

" Editing Utilities
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'tpope/vim-sleuth'
Plug 'tpope/vim-dispatch'
Plug 'scrooloose/nerdcommenter'
Plug 'godlygeek/tabular'
Plug 'terryma/vim-smooth-scroll'
Plug 'eraserhd/parinfer-rust', {'do': 'cargo build --release'}

" Syntax and Language Support
let g:polyglot_disabled = ['ftdetect']
Plug 'sheerun/vim-polyglot'
Plug 'preservim/vim-markdown'
Plug 'iamcco/markdown-preview.nvim', { 'do': { -> mkdp#util#install() }, 'for': ['markdown', 'vim-plug']}
Plug 'fatih/vim-go', { 'do': ':GoUpdateBinaries' }
Plug 'ziglang/zig.vim'
Plug 'dag/vim2hs'
Plug 'derekelkins/agda-vim'
Plug 'idris-hackers/idris-vim'
Plug 'elixir-editors/vim-elixir'

" Misc
Plug 'vimwiki/vimwiki'
Plug 'preservim/nerdtree'
Plug 'junegunn/goyo.vim'
Plug 'preservim/vim-colors-pencil'

call plug#end()

" Now process all of the configuration files that I have stored in my 'config'
" directory, which significantly cleans up this file.
for filename in sort(split(glob('~/.config/vim/config/*.vim'), '\n'))
    execute 'source '.filename
endfor

